<!-- ============================================
     JAVASCRIPT
     ============================================ -->
<script>
// =============================================
// QUESTIONNAIRE ENGINE
// =============================================
const TOTAL_Q = 7;
let curQ = 1;
const personality = {};

(function initDots() {
  const c = document.getElementById('qDots');
  for (let i = 1; i <= TOTAL_Q; i++) {
    const d = document.createElement('div');
    d.className = 'q-dot' + (i === 1 ? ' active' : '');
    d.dataset.q = i;
    d.onclick = () => { if (i <= curQ) { curQ = i; renderQ(); } };
    c.appendChild(d);
  }
})();

function renderQ() {
  document.querySelectorAll('.q-step').forEach(s => s.classList.toggle('active', parseInt(s.dataset.q) === curQ));
  document.querySelectorAll('.q-dot').forEach(d => {
    const n = parseInt(d.dataset.q);
    d.className = 'q-dot' + (n === curQ ? ' active' : '') + (n < curQ ? ' done' : '');
  });
  document.getElementById('qProgress').style.width = `${(curQ / TOTAL_Q) * 100}%`;
  document.getElementById('qPrev').style.visibility = curQ === 1 ? 'hidden' : 'visible';
  document.getElementById('qNext').textContent = curQ === TOTAL_Q ? 'Build My EVA \u2192' : 'Next \u2192';
  const isBuilding = curQ > TOTAL_Q;
  document.getElementById('qNav').style.display = isBuilding ? 'none' : 'flex';
  document.getElementById('buildScreen').classList.toggle('active', false);
  document.getElementById('demoChat').classList.toggle('active', false);
}

function qNext() { if (curQ < TOTAL_Q) { curQ++; renderQ(); } else { startBuild(); } }
function qPrev() { if (curQ > 1) { curQ--; renderQ(); } }
function skipToBuild() { startBuild(); }
function restartQ() {
  curQ = 1; renderQ();
  document.getElementById('qNav').style.display = 'flex';
  document.getElementById('buildScreen').classList.remove('active');
  document.getElementById('demoChat').classList.remove('active');
  document.getElementById('apiKeyModal').style.display = 'none';
  document.getElementById('chatWindow').style.display = 'none';
  chatHistory = [];
}

document.querySelectorAll('.choice-grid').forEach(grid => {
  grid.querySelectorAll('.choice-card').forEach(card => {
    card.onclick = () => {
      grid.querySelectorAll('.choice-card').forEach(c => c.classList.remove('selected'));
      card.classList.add('selected');
      personality[grid.dataset.field] = card.dataset.val;
    };
  });
});

function addRow() {
  const r = document.createElement('tr');
  r.innerHTML = '<td><input class="f-input" placeholder=""></td><td><input class="f-input" placeholder=""></td><td><input class="f-input" placeholder=""></td><td><input class="f-input" placeholder=""></td>';
  document.getElementById('pRows').appendChild(r);
}

function toggleFaq(el) { el.parentElement.classList.toggle('open'); }
function gv(id) { const el = document.getElementById(id); return el ? el.value.trim() : ''; }

// =============================================
// BUILD ANIMATION
// =============================================
function startBuild() {
  document.getElementById('qNav').style.display = 'none';
  document.querySelectorAll('.q-step').forEach(s => s.classList.remove('active'));
  document.getElementById('qProgress').style.width = '100%';
  document.getElementById('buildScreen').classList.add('active');

  const bars = [
    { fill: 'bf1', pct: 'bp1' }, { fill: 'bf2', pct: 'bp2' },
    { fill: 'bf3', pct: 'bp3' }, { fill: 'bf4', pct: 'bp4' }, { fill: 'bf5', pct: 'bp5' }
  ];
  const statuses = [
    'Analyzing your personality profile...', 'Mapping your schedule preferences...',
    'Learning your communication style...', 'Configuring workflow automations...',
    'Generating prompt templates...', 'Finalizing EVA...'
  ];
  const logLines = [
    ['arrow', '> Reading CEO profile data...'],
    ['check', '\u2713 Name: ' + (gv('q_name') || 'CEO')],
    ['check', '\u2713 Company: ' + (gv('q_company') || 'Startup')],
    ['arrow', '> Analyzing personality type...'],
    ['check', '\u2713 Crisis style: ' + (personality.crisis || 'adaptive')],
    ['check', '\u2713 Morning mode: ' + (personality.morning || 'focused')],
    ['arrow', '> Configuring communication engine...'],
    ['check', '\u2713 Email style: ' + (personality.emailStyle || 'professional')],
    ['check', '\u2713 Sign-off: ' + (gv('q_signoff') || 'Best')],
    ['arrow', '> Building schedule rules...'],
    ['check', '\u2713 Focus blocks loaded'],
    ['check', '\u2713 Meeting defaults set'],
    ['arrow', '> Generating 12 prompt templates...'],
    ['arrow', '> Compiling 3 workflows...'],
    ['check', '\u2713 EVA is ready.'],
  ];

  const log = document.getElementById('buildLog');
  log.innerHTML = '';

  let barIdx = 0;
  const barInterval = setInterval(() => {
    if (barIdx >= bars.length) { clearInterval(barInterval); return; }
    const b = bars[barIdx];
    document.getElementById(b.fill).style.width = '100%';
    document.getElementById(b.pct).textContent = '100%';
    document.getElementById('buildStatus').textContent = statuses[barIdx] || statuses[statuses.length - 1];
    barIdx++;
  }, 600);

  let logIdx = 0;
  const logInterval = setInterval(() => {
    if (logIdx >= logLines.length) { clearInterval(logInterval); setTimeout(() => launchDemo(), 800); return; }
    const [type, text] = logLines[logIdx];
    const div = document.createElement('div');
    div.className = 'line';
    div.innerHTML = `<span class="${type}">${text}</span>`;
    log.appendChild(div);
    log.scrollTop = log.scrollHeight;
    logIdx++;
  }, 350);
}

// =============================================
// SYSTEM PROMPT BUILDER
// =============================================
function buildSystemPrompt() {
  const name = gv('q_name') || 'the CEO';
  const company = gv('q_company') || 'the company';
  const stage = gv('q_stage') || 'startup';
  const team = gv('q_team') || 'small';
  const location = gv('q_location') || '';
  const tz = gv('q_tz') || '';
  const priorities = gv('q_priorities') || 'Not specified yet';
  const timesink = gv('q_timesink') || '';
  const crisis = personality.crisis || 'adaptive';
  const morning = personality.morning || 'flexible';
  const emailStyle = personality.emailStyle || 'professional';
  const signoff = gv('q_signoff') || 'Best';
  const length = gv('q_length') || 'Short';
  const peeve = gv('q_peeve') || '';
  const workStart = gv('q_start') || '8:00 AM';
  const workEnd = gv('q_end') || '6:00 PM';
  const focus = gv('q_focus') || '';
  const intMtg = gv('q_int') || '25 min';
  const extMtg = gv('q_ext') || '45 min';
  const mtgTool = gv('q_tool') || 'Zoom';

  // Gather people
  const people = [];
  document.querySelectorAll('#pRows tr').forEach(row => {
    const inputs = row.querySelectorAll('input');
    const n = inputs[0]?.value.trim();
    if (n) people.push({ name: n, role: inputs[1]?.value.trim(), rel: inputs[2]?.value.trim(), notes: inputs[3]?.value.trim() });
  });
  const peopleStr = people.length > 0
    ? people.map(p => `- ${p.name} (${p.role}) \u2014 ${p.rel}${p.notes ? '. ' + p.notes : ''}`).join('\n')
    : 'None listed yet.';

  const toolsList = [
    gv('q_email') && `Email: ${gv('q_email')}`,
    gv('q_cal') && `Calendar: ${gv('q_cal')}`,
    gv('q_task') && `Tasks: ${gv('q_task')}`,
    gv('q_chat') && `Chat: ${gv('q_chat')}`,
    gv('q_storage') && `Storage: ${gv('q_storage')}`,
    gv('q_expense') && `Expenses: ${gv('q_expense')}`
  ].filter(Boolean);
  const tools = toolsList.length > 0 ? toolsList.join('\n- ') : 'Not specified yet';

  return `You are EVA \u2014 ${name}'s AI Chief of Staff at ${company}.

ABOUT ${name.toUpperCase()}:
- Company: ${company} (${stage}, ~${team} people)
- Location: ${location} ${tz}
- Top priorities right now:
${priorities}
${timesink ? '- Biggest time sink: ' + timesink : ''}

PERSONALITY PROFILE:
- Under pressure: ${crisis} (${
  crisis === 'commander' ? 'jumps in and takes charge' :
  crisis === 'delegator' ? 'finds the right person and clears blockers' :
  crisis === 'analyst' ? 'gathers info before acting' :
  'stays calm and course-corrects quietly'
})
- Ideal morning: ${morning} (${
  morning === 'deep' ? 'deep work, no meetings until noon' :
  morning === 'standup' ? 'quick team standup then focus' :
  morning === 'social' ? 'coffee chats and catch-ups first' :
  'plans the entire week before doing anything'
})

COMMUNICATION STYLE:
- Email style: ${emailStyle} (${
  emailStyle === 'blunt' ? 'short, direct, no fluff' :
  emailStyle === 'warm' ? 'friendly and human, casual but professional' :
  emailStyle === 'structured' ? 'numbered points, organized, clear' :
  'thoughtful, diplomatic, considers all sides'
})
- Email sign-off (ONLY use when drafting an actual email, never in regular chat): "${signoff}"
- Preferred response length: ${length}
${peeve ? '- Pet peeve: ' + peeve : ''}

SCHEDULE RULES:
- Work hours: ${workStart} \u2013 ${workEnd} ${tz}
- Focus blocks: ${focus || 'None set'}
- Meeting defaults: ${intMtg} internal, ${extMtg} external
- Meeting tool: ${mtgTool}

KEY PEOPLE:
${peopleStr}

PREFERRED TOOLS:
- ${tools}

YOUR BEHAVIOR RULES:
1. You are EVA. Speak in first person. You are warm, sharp, direct, and anticipatory.
2. Match ${name}'s communication style exactly. If they're blunt, be blunt. If they're warm, be warm.
3. Keep responses ${length.toLowerCase().includes('short') ? 'very concise (3-5 sentences max)' : 'focused and actionable'}.
4. Always end with a clear next step or ask a clarifying question.
5. You handle: calendar, scheduling, email drafting, meeting prep, follow-ups, travel, expenses, document prep, vendor coordination.
6. You do NOT: write code, make marketing decisions, make strategic business decisions, or speak publicly for ${name}.
7. Be anticipatory \u2014 if ${name} mentions a meeting, proactively offer to prep a briefing.
8. Reference their priorities when triaging urgency.
9. When appropriate, naturally mention that to connect to their real calendar/email/tools, they'd need to install EVA locally on their machine.
10. You are currently running as a live demo on the OpenClaw website. If they want the full experience with real tool integrations, they can purchase and download EVA.

YOUR OPENING MESSAGE \u2014 THIS IS CRITICAL:
This is your first conversation with ${name}. Your opening message must do ALL of the following in order:

1. GREET them by first name, warmly and confidently.

2. PROFILE ASSESSMENT \u2014 Analyze their answers in depth and present a short, insightful personality read-back. This is the "aha moment" where they feel truly understood. Cover:
   - Their leadership style based on their crisis response and morning routine answers
   - Their communication DNA based on their email style choice
   - A sharp observation about their priorities \u2014 what they reveal about where the company is right now
   - Any interesting tension or pattern you notice (e.g., "You're a delegator who starts with deep work \u2014 that tells me you trust your team but protect your own thinking time. That's rare.")
   Be specific. Be perceptive. Make them feel like you actually SEE them.

3. QUALITY CHECK \u2014 Inspect their answers carefully for:
   - Nonsense, gibberish, or clearly fake entries (random letters, "asdf", joke answers, "test test")
   - Empty or vague priorities that don't actually say anything ("do stuff", "things")
   - Contradictions (e.g., "no meetings ever" but external meeting default is 60 min)
   - Missing critical info that would make you less effective
   If you find ANY of these issues, call them out directly but with warmth and humor. Example: "I noticed your top priority is 'asdfjkl' \u2014 I'm good, but I'm not THAT good. Want to give me something real to work with?" or "Your priorities are blank \u2014 which either means you're zen or you skipped that part. Either way, I need to know what matters to you."
   Do NOT pretend bad answers are fine. A real Chief of Staff would push back, and so should you.

4. DEMONSTRATE VALUE \u2014 Based on their REAL answers (if they gave good ones), offer to do something specific and useful right now. Pick one:
   - Draft a Monday morning briefing based on their priorities
   - Write an email in their voice to one of their key people
   - Build a weekly schedule template based on their rules
   - Create a follow-up tracker for their active threads
   Make the offer concrete, not generic.

Keep the whole opening message to 3-4 paragraphs. Don't use bullet points \u2014 write it conversationally, like a sharp colleague who just finished reading their file.`;
}

// =============================================
// OPENAI CHAT ENGINE
// =============================================
let apiKey = '';
let chatHistory = [];
let isStreaming = false;

function launchDemo() {
  document.getElementById('buildScreen').classList.remove('active');
  const dc = document.getElementById('demoChat');
  dc.classList.add('active');

  // Check if we have a stored API key
  apiKey = sessionStorage.getItem('eva_api_key') || '';
  if (apiKey) {
    connectEva();
  } else {
    document.getElementById('apiKeyModal').style.display = 'block';
    document.getElementById('chatWindow').style.display = 'none';
  }
}

function showApiModal() {
  document.getElementById('apiKeyModal').style.display = 'block';
  document.getElementById('chatWindow').style.display = 'none';
  document.getElementById('apiKeyInput').value = apiKey;
}

async function connectEva() {
  const inputKey = document.getElementById('apiKeyInput').value.trim();
  if (inputKey) {
    apiKey = inputKey;
    sessionStorage.setItem('eva_api_key', apiKey);
  }

  if (!apiKey) {
    document.getElementById('apiKeyInput').style.borderColor = 'var(--destructive)';
    return;
  }

  document.getElementById('apiKeyModal').style.display = 'none';
  document.getElementById('chatWindow').style.display = 'block';

  const body = document.getElementById('chatBody');
  body.innerHTML = '';

  // Initialize chat with system prompt
  chatHistory = [{ role: 'system', content: buildSystemPrompt() }];

  // Send initial greeting request
  await streamResponse();
}

function addMsg(role, text) {
  const body = document.getElementById('chatBody');
  const div = document.createElement('div');
  div.className = `chat-msg msg-${role === 'assistant' ? 'eva' : 'user'}`;
  div.textContent = text;
  body.appendChild(div);
  body.scrollTop = body.scrollHeight;
  return div;
}

function addTyping() {
  const body = document.getElementById('chatBody');
  const typing = document.createElement('div');
  typing.className = 'chat-typing';
  typing.id = 'typingIndicator';
  typing.innerHTML = '<span></span><span></span><span></span>';
  body.appendChild(typing);
  body.scrollTop = body.scrollHeight;
}

function removeTyping() {
  const t = document.getElementById('typingIndicator');
  if (t) t.remove();
}

async function sendMsg() {
  if (isStreaming) return;
  const input = document.getElementById('chatInput');
  const text = input.value.trim();
  if (!text) return;

  input.value = '';
  addMsg('user', text);
  chatHistory.push({ role: 'user', content: text });
  await streamResponse();
}

async function streamResponse() {
  isStreaming = true;
  const input = document.getElementById('chatInput');
  input.disabled = true;

  addTyping();

  try {
    const res = await fetch('https://api.openai.com/v1/chat/completions', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${apiKey}`
      },
      body: JSON.stringify({
        model: 'gpt-4o-mini',
        messages: chatHistory,
        stream: true,
        max_tokens: 800,
        temperature: 0.8
      })
    });

    if (!res.ok) {
      removeTyping();
      const err = await res.json().catch(() => ({}));
      if (res.status === 401) {
        addMsg('assistant', 'Hmm, that API key doesn\'t seem to work. Click the gear icon to try a different one.');
        apiKey = '';
        sessionStorage.removeItem('eva_api_key');
      } else {
        addMsg('assistant', `Something went wrong (${res.status}). ${err.error?.message || 'Try again in a moment.'}`);
      }
      isStreaming = false;
      input.disabled = false;
      return;
    }

    removeTyping();

    // Create the message element for streaming
    const body = document.getElementById('chatBody');
    const msgDiv = document.createElement('div');
    msgDiv.className = 'chat-msg msg-eva streaming';
    body.appendChild(msgDiv);

    const reader = res.body.getReader();
    const decoder = new TextDecoder();
    let fullText = '';
    let buffer = '';

    while (true) {
      const { done, value } = await reader.read();
      if (done) break;

      buffer += decoder.decode(value, { stream: true });
      const lines = buffer.split('\n');
      buffer = lines.pop(); // Keep incomplete line in buffer

      for (const line of lines) {
        if (!line.startsWith('data: ')) continue;
        const data = line.slice(6);
        if (data === '[DONE]') break;

        try {
          const json = JSON.parse(data);
          const delta = json.choices?.[0]?.delta?.content;
          if (delta) {
            fullText += delta;
            msgDiv.textContent = fullText;
            body.scrollTop = body.scrollHeight;
          }
        } catch (e) { /* skip malformed chunks */ }
      }
    }

    msgDiv.classList.remove('streaming');
    chatHistory.push({ role: 'assistant', content: fullText });

  } catch (err) {
    removeTyping();
    addMsg('assistant', 'Connection error. Check your internet and try again.');
  }

  isStreaming = false;
  input.disabled = false;
  input.focus();
}

// =============================================
// SMOOTH SCROLL
// =============================================
document.querySelectorAll('a[href^="#"]').forEach(a => {
  a.addEventListener('click', e => {
    e.preventDefault();
    const t = document.querySelector(a.getAttribute('href'));
    if (t) t.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
});
</script>

</body>
</html>
